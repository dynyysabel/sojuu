# --- TERMINAL INTERFACE LOGIC ---
def start_terminal_loop(loop):
    while True:
        try:
            cmd_input = input("Bot-Terminal> ").strip().split()
            if not cmd_input:
                continue
            cmd = cmd_input[0].lower()
            args = cmd_input[1:]
            asyncio.run_coroutine_threadsafe(handle_terminal_command(cmd, args), loop)
        except Exception as e:
            print(f"[ERROR] Terminal exception occurred: {e}")

async def handle_terminal_command(cmd, args):
    guild = bot.get_guild(GUILD_ID)
    if not guild:
        print("[WARN] Guild ID invalid or bot hasn't finished loading yet.")
        return

    if cmd == "help":
        print("\n--- Available Terminal Commands ---")
        print("  status                       - Shows active ticket count")
        print("  closeall                     - Deletes all channels inside ticket category")
        print("  say <chan_id> <content_str>  - Sends combined text || embed || image layout")
        print("  stop                         - Gracefully logs the bot out")
        print("-----------------------------------\n")
        
    elif cmd == "status":
        category = guild.get_channel(TICKET_CATEGORY_ID)
        ticket_count = len(category.text_channels) if category else 0
        print(f"\n--- Bot Status ---\nActive Tickets Open: {ticket_count}\n------------------\n")
        
    elif cmd == "closeall":
        category = guild.get_channel(TICKET_CATEGORY_ID)
        if not category: return
        for channel in category.text_channels:
            if "order-" in channel.name or "report-" in channel.name:
                await channel.delete()
        print("[SYSTEM] Mass cleanup complete.")
        
    elif cmd == "say":
        if len(args) < 2:
            print("[ERROR] Usage: say [channel_id] [text || Title|Desc|#Hex || img_url]")
            return
            
        try:
            target_channel_id = int(args[0])
        except ValueError:
            print("[ERROR] Invalid Channel ID input.")
            return
            
        channel = bot.get_channel(target_channel_id)
        if not channel:
            print("[ERROR] Channel not found or bot lacks access.")
            return
            
        content_str = " ".join(args[1:])
        success = await send_combined_message(channel, content_str)
        if success:
            print(f"[SUCCESS] Combined layout dispatched to #{channel.name}")
        else:
            print("[ERROR] Could not parse any valid text, embed or image details.")
            
    elif cmd == "stop":
        await bot.close()
        sys.exit(0)


