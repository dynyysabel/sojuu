# --- CUSTOM ID + ADMIN CHECK ---
def is_admin_or_allowed_id():
    async def predicate(ctx):
        has_admin = ctx.author.guild_permissions.administrator
        is_allowed_id = ctx.author.id in ALLOWED_USER_IDS
        return has_admin and is_allowed_id
    return commands.check(predicate)


# --- COMBINED SAY HELPER FUNCTION ---
async def send_combined_message(target, content_str):
    """Parses and sends text, embed, and image from a single combined string."""
    sections = content_str.split("||")
    
    plain_text = sections[0].strip() if len(sections) > 0 else ""
    embed_section = sections[1].strip() if len(sections) > 1 else ""
    image_url = sections[2].strip() if len(sections) > 2 else ""

    kwargs = {}
    if plain_text:
        kwargs["content"] = plain_text

    if embed_section or image_url:
        title, desc, color_str = "", "", "2f3136"
        
        if embed_section:
            parts = [p.strip() for p in embed_section.split("|")]
            title = parts[0]
            desc = parts[1] if len(parts) > 1 else ""
            if len(parts) > 2:
                color_str = parts[2].replace("#", "")

        try:
            embed_color = int(color_str, 16)
        except ValueError:
            embed_color = 0x2f3136

        embed = discord.Embed(color=embed_color)
        if title:
            embed.title = title
        if desc:
            embed.description = desc
        if image_url:
            embed.set_image(url=image_url)
            
        kwargs["embed"] = embed

    if kwargs:
        await target.send(**kwargs)
        return True
    return False


